{
  "name": "@synnovator/web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "node scripts/generate-static-data.mjs && node ../../scripts/generate-theme-css.mjs",
    "dev": "node scripts/generate-static-data.mjs && node ../../scripts/generate-theme-css.mjs && next dev --turbopack",
    "build": "node scripts/generate-static-data.mjs && node ../../scripts/generate-theme-css.mjs && next build",
    "build:worker": "node scripts/generate-static-data.mjs && node ../../scripts/generate-theme-css.mjs && opennextjs-cloudflare build",
    "start": "next start",
    "deploy": "opennextjs-cloudflare build && wrangler deploy",
    "deploy:preview": "opennextjs-cloudflare build && wrangler versions upload",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1003.0",
    "@aws-sdk/s3-request-presigner": "^3.1003.0",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/rest": "^22.0.1",
    "@opennextjs/cloudflare": "^1",
    "@synnovator/shared": "workspace:*",
    "@synnovator/ui": "workspace:*",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.576.0",
    "next": "^15",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4",
    "@mdx-js/mdx": "^3.1.1",
    "@tailwindcss/postcss": "^4.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "jsdom": "^28.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.69.0"
  }
}
