---
export const prerender = false;
import BaseLayout from '../layouts/BaseLayout.astro';
import ProfileCreateForm from '../components/forms/ProfileCreateForm';
import { getLangFromUrl } from '../lib/i18n';
import type { Lang } from '../lib/i18n';

const lang: Lang = getLangFromUrl(Astro.url);
---

<BaseLayout title="Create Profile" description="Create your Synnovator hacker profile" lang={lang}>
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-3xl font-heading font-bold text-white mb-8">Create Your Profile</h1>
    <ProfileCreateForm client:load lang={lang} />
  </div>
</BaseLayout>
