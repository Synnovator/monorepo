---
import { localize } from '../lib/i18n';
import type { Lang } from '../lib/i18n';
import { ShieldCheckIcon } from './icons';

interface Props {
  judge: {
    github: string;
    name: string;
    name_zh?: string;
    title?: string;
    affiliation?: string;
    expertise?: string;
    conflict_declaration?: string;
  };
  lang: Lang;
  profileSlug?: string;
}

const { judge, lang, profileSlug } = Astro.props;
const profileUrl = profileSlug ? `/hackers/${profileSlug}/` : undefined;
---

<div class="flex items-start gap-4 p-4 rounded-lg border border-secondary-bg bg-dark-bg">
  {profileUrl ? (
    <a href={profileUrl} class="shrink-0 group">
      <img
        src={`https://github.com/${judge.github}.png`}
        alt={localize(lang, judge.name, judge.name_zh)}
        class="w-12 h-12 rounded-full bg-secondary-bg ring-2 ring-transparent group-hover:ring-lime-primary transition-all"
        loading="lazy"
      />
    </a>
  ) : (
    <img
      src={`https://github.com/${judge.github}.png`}
      alt={localize(lang, judge.name, judge.name_zh)}
      class="w-12 h-12 rounded-full bg-secondary-bg shrink-0"
      loading="lazy"
    />
  )}
  <div>
    {profileUrl ? (
      <a href={profileUrl} class="text-white font-medium text-sm hover:text-lime-primary transition-colors">
        {localize(lang, judge.name, judge.name_zh)}
      </a>
    ) : (
      <p class="text-white font-medium text-sm">
        {localize(lang, judge.name, judge.name_zh)}
      </p>
    )}
    {judge.title && <p class="text-muted text-xs">{judge.title}</p>}
    {judge.affiliation && <p class="text-muted text-xs">{judge.affiliation}</p>}
    {judge.expertise && (
      <p class="text-cyan text-xs mt-1">{judge.expertise}</p>
    )}
    {judge.conflict_declaration && (
      <a
        href={judge.conflict_declaration}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1 mt-2 text-xs text-lime-primary hover:underline"
      >
        <ShieldCheckIcon size={14} className="shrink-0" />
        {lang === 'zh' ? '已提交利益冲突声明' : 'Conflict declaration filed'}
      </a>
    )}
  </div>
</div>
